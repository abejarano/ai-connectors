{
  "name": "@abejarano/ai-connectors",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "build": "bun run clean && bun run build.ts",
    "test": "bun test",
    "prepublishOnly": "bun run build",
    "publish:dry": "bun publish --dry-run",
    "publish:npm": "bun publish --access public",
    "clean": "rimraf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/bun": "latest",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/genai": "^2.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abejarano/ai-connectors.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}